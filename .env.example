APP_NAME=istedalis
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/database/database.sqlite
# Render/PostgreSQL icin:
# DB_CONNECTION=pgsql
# DATABASE_URL=postgres://user:password@host:5432/database

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
CACHE_STORE=file
QUEUE_CONNECTION=sync

BACKUP_RETENTION_DAYS=14
AUTO_BACKUP_TOKEN=

ADMIN_STAFF_NO=3001
ADMIN_PASSWORD=
ADMIN_NAME=Sistem
ADMIN_SURNAME=Yoneticisi
